       IDENTIFICATION DIVISION.
       PROGRAM-ID. REPORTGEN.
       AUTHOR. LEGACYLIFT-SAMPLE.

       DATA DIVISION.
       WORKING-STORAGE SECTION.
       01 WS-REPORT-DATA.
          05 WS-REPORT-TITLE   PIC X(50).
          05 WS-REPORT-DATE    PIC 9(8).
          05 WS-TOTAL-RECORDS  PIC 9(6).
          05 WS-TOTAL-AMOUNT   PIC 9(10)V99.
          05 WS-REPORT-STATUS  PIC X(10).

       01 WS-LINE-BUFFER       PIC X(132).
       01 WS-PAGE-COUNT        PIC 9(3) VALUE 0.

       PROCEDURE DIVISION.
       REPORT-MAIN.
           PERFORM INITIALIZE-REPORT.
           PERFORM WRITE-HEADER.
           PERFORM WRITE-DETAIL-LINES.
           PERFORM WRITE-FOOTER.
           PERFORM CLOSE-REPORT.
           STOP RUN.

       INITIALIZE-REPORT.
           MOVE "PAYROLL SUMMARY REPORT" TO WS-REPORT-TITLE.
           MOVE "PENDING" TO WS-REPORT-STATUS.
           ADD 1 TO WS-PAGE-COUNT.

       WRITE-HEADER.
           STRING WS-REPORT-TITLE DELIMITED BY SPACES
                  " - PAGE " DELIMITED BY SIZE
                  WS-PAGE-COUNT DELIMITED BY SIZE
                  INTO WS-LINE-BUFFER.
           DISPLAY WS-LINE-BUFFER.

       WRITE-DETAIL-LINES.
           IF WS-TOTAL-RECORDS > 0
               DISPLAY "RECORDS PROCESSED: " WS-TOTAL-RECORDS
               DISPLAY "TOTAL AMOUNT: " WS-TOTAL-AMOUNT
           ELSE
               DISPLAY "NO RECORDS TO REPORT"
           END-IF.

       WRITE-FOOTER.
           MOVE "COMPLETE" TO WS-REPORT-STATUS.
           DISPLAY "REPORT STATUS: " WS-REPORT-STATUS.

       CLOSE-REPORT.
           DISPLAY "REPORT GENERATION COMPLETE".
           CALL "AUDITLOG" USING WS-REPORT-DATA.
