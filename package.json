{
  "name": "legacylift",
  "version": "0.1.0",
  "description": "AI-powered legacy code analysis and modernization studio",
  "main": "electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "electron:dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "electron:build": "vite build && electron-builder"
  },
  "dependencies": {
    "@monaco-editor/react": "^4.7.0",
    "framer-motion": "^12.0.0",
    "lucide-react": "^0.470.0",
    "react": "^18.3.0",
    "react-diff-viewer-continued": "^4.0.0",
    "react-dom": "^18.3.0",
    "react-resizable-panels": "^4.7.1",
    "react-router-dom": "^7.0.0",
    "recharts": "^2.15.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.4.0",
    "concurrently": "^9.0.0",
    "electron": "^36.0.0",
    "electron-builder": "^26.0.0",
    "vite": "^6.2.0",
    "wait-on": "^8.0.0"
  },
  "build": {
    "appId": "com.legacylift.app",
    "productName": "LegacyLift",
    "directories": {
      "buildResources": "electron",
      "output": "dist-electron"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "legacylift/**/*",
      "requirements.txt",
      "package.json"
    ],
    "win": {
      "target": "nsis",
      "icon": "public/icon.png"
    }
  }
}
